---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About · Fliss Singing">
  <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">About</h1>
  <p class="mt-4 max-w-2xl text-pretty text-zinc-300">
    Short bio, musical influences, and highlight performances will live here.
  </p>

  <div class="mt-8 rounded-xl border border-white/10 bg-white/5 p-5">
    <p class="text-sm font-medium text-white">Placeholder</p>
    <p class="mt-2 text-sm text-zinc-300">
      We’ll replace this with real copy once you share a few details (style, favourite songs, achievements).
    </p>
  </div>
</Layout>

