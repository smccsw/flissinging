---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact · Fliss Singing">
  <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Contact</h1>
  <p class="mt-4 max-w-2xl text-pretty text-zinc-300">
    Booking/contact details will go here. In the static version we can use a lightweight form provider.
  </p>

  <div class="mt-8 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-white/10 bg-white/5 p-5">
      <p class="text-sm font-medium text-white">Email</p>
      <p class="mt-2 text-sm text-zinc-300">Add contact email in CMS settings.</p>
    </div>
    <div class="rounded-xl border border-white/10 bg-white/5 p-5">
      <p class="text-sm font-medium text-white">Social</p>
      <p class="mt-2 text-sm text-zinc-300">Instagram / YouTube / TikTok links.</p>
    </div>
  </div>
</Layout>

