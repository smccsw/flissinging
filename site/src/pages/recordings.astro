---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Recordings · Fliss Singing">
  <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Recordings</h1>
  <p class="mt-4 max-w-2xl text-pretty text-zinc-300">
    This page will pull recordings from the CMS. For now, it’s a placeholder with a mobile-first layout.
  </p>

  <div class="mt-8 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-white/10 bg-white/5 p-5">
      <p class="text-sm font-medium text-white">Coming soon</p>
      <p class="mt-2 text-sm text-zinc-300">Filterable grid + detail pages.</p>
    </div>
    <div class="rounded-xl border border-white/10 bg-white/5 p-5">
      <p class="text-sm font-medium text-white">Media types</p>
      <p class="mt-2 text-sm text-zinc-300">YouTube/Vimeo embeds, plus optional audio uploads.</p>
    </div>
  </div>
</Layout>

