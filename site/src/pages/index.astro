---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Fliss Singing">
	<section class="py-10 sm:py-16">
		<p class="text-sm uppercase tracking-[0.2em] text-zinc-400">Singing portfolio</p>
		<h1 class="mt-4 text-balance text-4xl font-semibold tracking-tight sm:text-6xl">
			A home for recordings, performances, and the story behind the voice.
		</h1>
		<p class="mt-6 max-w-2xl text-pretty text-lg leading-relaxed text-zinc-300">
			This site will showcase audio/video recordings and a scroll-driven experience inspired by your reference sites.
			Content will be managed via a CMS so updates don’t require Git.
		</p>

		<div class="mt-8 flex flex-col gap-3 sm:flex-row">
			<a
				href="/recordings"
				class="inline-flex items-center justify-center rounded-md bg-white px-4 py-2 text-sm font-medium text-zinc-950 hover:bg-zinc-200"
			>
				View recordings
			</a>
			<a
				href="/contact"
				class="inline-flex items-center justify-center rounded-md border border-white/15 px-4 py-2 text-sm font-medium text-white hover:border-white/30"
			>
				Contact / booking
			</a>
		</div>
	</section>

	<section class="mt-10 grid gap-4 sm:grid-cols-3">
		<div class="rounded-xl border border-white/10 bg-white/5 p-5">
			<h2 class="text-sm font-semibold text-white">Scroll story</h2>
			<p class="mt-2 text-sm leading-relaxed text-zinc-300">
				Pinned panels + scrubbed transitions (desktop), with a clean stacked layout on mobile.
			</p>
		</div>
		<div class="rounded-xl border border-white/10 bg-white/5 p-5">
			<h2 class="text-sm font-semibold text-white">Recordings</h2>
			<p class="mt-2 text-sm leading-relaxed text-zinc-300">
				A filterable library of audio/video, with detail pages and beautiful playback UX.
			</p>
		</div>
		<div class="rounded-xl border border-white/10 bg-white/5 p-5">
			<h2 class="text-sm font-semibold text-white">Mobile-first</h2>
			<p class="mt-2 text-sm leading-relaxed text-zinc-300">
				Touch-friendly navigation, fast loads, and graceful reduced-motion support.
			</p>
		</div>
	</section>
</Layout>
