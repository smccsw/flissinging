---
/**
 * A minimal scroll-driven section.
 * - Desktop: pinned container + scrubbed panel fades.
 * - Mobile / reduced-motion: stacked content (no JS).
 */
type Panel = {
  eyebrow: string;
  title: string;
  body: string;
};

const panels: Panel[] = [
  {
    eyebrow: "Chapter 01",
    title: "Warm-up",
    body: "A calm intro that sets the tone. On desktop, this becomes a pinned sequence you scroll through."
  },
  {
    eyebrow: "Chapter 02",
    title: "Voice",
    body: "The performance takes focus. This is where recordings and highlights will live."
  },
  {
    eyebrow: "Chapter 03",
    title: "Stage",
    body: "Bring it home with bookings, socials, and a clear next step."
  }
];
---

<section class="mt-14">
  <div class="flex items-end justify-between gap-6">
    <div>
      <p class="text-sm uppercase tracking-[0.2em] text-zinc-400">Scroll story</p>
      <h2 class="mt-3 text-balance text-2xl font-semibold tracking-tight sm:text-3xl">
        A pinned, scroll-driven narrative (desktop) with a clean mobile fallback.
      </h2>
    </div>
    <p class="hidden max-w-sm text-pretty text-sm text-zinc-400 sm:block">
      This is a foundation for the “Charles Leclerc”-style scroll choreography you liked.
    </p>
  </div>

  <!-- Mobile / reduced-motion fallback: always readable stacked panels -->
  <div class="mt-6 grid gap-4 lg:hidden">
    {panels.map((p) => (
      <article class="rounded-xl border border-white/10 bg-white/5 p-5">
        <p class="text-xs font-medium uppercase tracking-[0.2em] text-zinc-400">{p.eyebrow}</p>
        <h3 class="mt-3 text-lg font-semibold tracking-tight text-white">{p.title}</h3>
        <p class="mt-2 text-sm leading-relaxed text-zinc-300">{p.body}</p>
      </article>
    ))}
  </div>

  <!-- Desktop: pinned panels with scroll-driven transitions -->
  <div class="relative mt-6 hidden lg:block">
    <div
      data-scrollstory-root
      class="relative overflow-hidden rounded-2xl border border-white/10 bg-gradient-to-b from-white/5 to-transparent"
    >
      <div class="grid min-h-[70vh] grid-cols-12 gap-6 p-8">
        <div class="col-span-5">
          <p class="text-sm text-zinc-400">Scroll</p>
          <p class="mt-2 text-balance text-3xl font-semibold tracking-tight">
            Each panel fades and slides as you move.
          </p>
          <p class="mt-4 text-sm leading-relaxed text-zinc-300">
            On smaller screens we avoid pinning and keep everything stacked, touch-friendly, and fast.
          </p>
        </div>

        <div class="col-span-7">
          <div class="relative min-h-[48vh]">
            {panels.map((p, idx) => (
              <article
                data-scrollstory-panel
                data-panel-index={idx}
                class="absolute inset-0 flex flex-col justify-end rounded-xl border border-white/10 bg-zinc-950/40 p-6"
                style={`opacity: ${idx === 0 ? 1 : 0}; transform: translateY(${idx === 0 ? 0 : 16}px);`}
              >
                <p class="text-xs font-medium uppercase tracking-[0.2em] text-zinc-400">{p.eyebrow}</p>
                <h3 class="mt-3 text-2xl font-semibold tracking-tight text-white">{p.title}</h3>
                <p class="mt-2 max-w-xl text-sm leading-relaxed text-zinc-300">{p.body}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- client-only animation -->
    <script>
      import { initScrollStory } from "../lib/scrollstory";
      initScrollStory();
    </script>
  </div>
</section>

