---
export type Props = {
  title?: string;
  description?: string;
};

const { title = "Fliss Singing", description = "Singing portfolio and recordings." } = Astro.props;

import FreeformBackground from "../components/FreeformBackground.astro";
import { FX_PALETTES } from "../lib/fxPalette";
import { sitePath } from "../lib/sitePath";
---

<style>
  @import "../styles/global.css";
  @media (prefers-reduced-motion: reduce) {
    [data-fx-controls] {
      display: none;
    }
  }
</style>

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={sitePath("favicon.svg")} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300..800&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-dvh bg-zinc-950 font-[Inter] text-zinc-100 antialiased">
    <a
      href="#content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-zinc-900 focus:px-3 focus:py-2"
    >
      Skip to content
    </a>

    <FreeformBackground />

    <div class="mx-auto flex min-h-dvh max-w-6xl flex-col px-4">
      <div aria-hidden="true" class="pointer-events-none fixed inset-0 -z-10">
        <div
          data-fx-glow="a"
          class="absolute left-1/2 top-[-30vh] h-[70vh] w-[70vh] -translate-x-1/2 rounded-full blur-3xl"
          style="background: radial-gradient(circle, rgba(168,85,247,0.16) 0%, transparent 68%);"
        />
        <div
          data-fx-glow="b"
          class="absolute bottom-[-35vh] left-[-20vh] h-[80vh] w-[80vh] rounded-full blur-3xl"
          style="background: radial-gradient(circle, rgba(34,211,238,0.14) 0%, transparent 68%);"
        />
      </div>

      <header class="sticky top-0 z-40 -mx-4 border-b border-white/10 bg-zinc-950/70 px-4 backdrop-blur">
        <div class="flex flex-col gap-3 py-3 sm:flex-row sm:items-center sm:justify-between sm:gap-4 sm:py-2.5">
          <div class="flex items-center justify-between gap-6 sm:justify-start">
            <a href={sitePath("")} class="shrink-0 font-semibold tracking-tight">Fliss Singing</a>
            <nav class="flex flex-wrap items-center justify-end gap-x-4 gap-y-1 text-sm text-zinc-200">
              <a class="hover:text-white" href={sitePath("recordings")}>Recordings</a>
              <a class="hover:text-white" href={sitePath("about")}>About</a>
              <a class="hover:text-white" href={sitePath("contact")}>Contact</a>
            </nav>
          </div>

          <div
            data-fx-controls
            class="flex flex-wrap items-center gap-2 border-t border-white/10 pt-3 sm:border-t-0 sm:pt-0 md:gap-3"
          >
            <span class="text-[10px] font-medium uppercase tracking-[0.2em] text-zinc-500">Background</span>
            <div
              class="flex flex-wrap items-center gap-1 rounded-xl border border-white/10 bg-zinc-950/55 px-1.5 py-1 sm:gap-1.5 sm:px-2 sm:py-1.5"
              role="group"
              aria-label="Background color palette"
            >
              {
                FX_PALETTES.map((p) => (
                  <button
                    type="button"
                    data-fx-palette={p.id}
                    title={p.label}
                    aria-label={`Palette: ${p.label}`}
                    aria-pressed="false"
                    class="fx-palette-swatch h-7 w-7 shrink-0 rounded-full ring-2 ring-zinc-700/60 transition hover:ring-white/35 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/45 sm:h-8 sm:w-8"
                    style={`background: linear-gradient(135deg, rgb(${p.washA.join(",")}), rgb(${p.washB.join(",")}))`}
                  />
                ))
              }
            </div>
            <button
              type="button"
              data-freeform-toggle
              class="shrink-0 rounded-lg border border-white/15 bg-white/5 px-3 py-2 text-xs font-medium tracking-wide text-zinc-200 hover:border-white/25 hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/30"
            >
              FX
            </button>
          </div>
        </div>
      </header>

      <main id="content" class="flex-1 py-10">
        <slot />
      </main>

      <footer class="border-t border-white/10 py-8 text-sm text-zinc-400">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
          <p>© {new Date().getFullYear()} Fliss Singing</p>
          <p class="text-zinc-500">Built as a portfolio project.</p>
        </div>
      </footer>
    </div>
  </body>
</html>

